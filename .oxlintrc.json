{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["import", "typescript", "unicorn", "oxc"],
  "categories": {
    "correctness": "error"
  },
  "ignorePatterns": ["dist", "node_modules"],
  "rules": {},
  "env": {
    "browser": true,
    "builtin": true
  },
  "overrides": [
    {
      "files": ["vite.config.ts"],
      "env": {
        "browser": false,
        "node": true
      }
    }
  ]
}
