{
  "name": "pixijs-game-lab",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "lint": "oxlint src vite.config.ts --tsconfig tsconfig.json --deny-warnings",
    "lint:fix": "oxlint src vite.config.ts --tsconfig tsconfig.json --fix",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "check": "npm run lint && npm run format:check && npm run typecheck",
    "build": "npm run check && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@barvynkoa/particle-emitter": "^0.0.1",
    "gsap": "^3.14.2",
    "pixi.js": "^8.17.1"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "javascript-obfuscator": "^5.4.1",
    "oxlint": "^1.59.0",
    "prettier": "^3.8.1",
    "prettier-plugin-organize-imports": "^4.3.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.7",
    "vite-plugin-javascript-obfuscator": "^3.1.0",
    "vite-tsconfig-paths": "^5.1.4"
  }
}
